{
  "name": "kafka-visual-playground",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @kplay/web run dev",
    "dev:demo": "KAFKA_MODE=demo npm --workspace @kplay/web run dev",
    "build": "npm run build --workspaces --if-present",
    "start": "npm --workspace @kplay/web run start",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:e2e": "env -u NO_COLOR playwright test",
    "kafka:cleanup": "tsx scripts/kafka-cleanup.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22"
  }
}
